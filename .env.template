# Scout Environment Variables
# Copy to .env and fill in values

# Set to "false" to use real APIs (requires API keys below)
MOCK_MODE=false

# Nova Act API key (from nova.amazon.com/act)
NOVA_ACT_API_KEY=

# AWS Bedrock (us-east-1 region required for Nova 2 Lite)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Bedrock model (Nova 2 Lite via cross-region inference)
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# Server
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]
