# Mock mode — set to true to use mock data (no API keys needed)
MOCK_MODE=true

# Nova Act (set MOCK_MODE=false when using real APIs)
NOVA_ACT_API_KEY=your_nova_act_api_key_here

# AWS Bedrock (Nova 2 Lite)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Backend
DATABASE_URL=sqlite:///./scout.db
PORT=8000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
